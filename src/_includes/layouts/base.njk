<!doctype html>
<html lang="{{ metadata.language }}">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ title or metadata.title }}</title>
		<meta name="description" content="{{ description or metadata.description }}">
		<link rel="alternate" href="/feed/feed.xml" type="application/atom+xml" title="{{ metadata.title }}">

		{#- Mona Sans is used for body copy and headings (see --font-base in
			variables.css) and is on the critical rendering path for nearly
			every element, so preload it to start the fetch alongside the
			HTML parse instead of waiting on CSSOM/style computation. Fonts
			are always fetched in CORS mode per spec, so `crossorigin` is
			required here even though the file is same-origin — omitting it
			causes the browser to fetch the file twice. #}
		<link rel="preload" href="/assets/fonts/MonaSans.woff2" as="font" type="font/woff2" crossorigin>

		{#- Uncomment this if you’d like folks to know that you used Eleventy to build your site!  #}
		{#- <meta name="generator" content="{{ eleventy.generator }}"> #}

		{#-
		Plain-text bundles are provided via the `eleventy-plugin-bundle` plugin:
		1. CSS:
			* Add to a per-page bundle using `{% css %}{% endcss %}`
			* Retrieve bundle content using `{% getBundle "css" %}` or `{% getBundleFileUrl "css" %}`
		2. Or for JavaScript:
			* Add to a per-page bundle using `{% js %}{% endjs %}`
			* Retrieve via `{% getBundle "js" %}` or `{% getBundleFileUrl "js" %}`
		3. Learn more: https://github.com/11ty/eleventy-plugin-bundle
		#}

		{#- CSS: same pipeline in dev (`npm start`) and production (`npm run
			build`). global.css is added to the `css` bundle; its transform
			(postcss-import-glob, see eleventy.config.js) resolves every @import
			— plain paths and globs like "blocks/*.css" — relative to src/css/,
			inlining everything into one content-hashed file. #}
		<style>{% include "src/assets/css/global.css" %}</style>
		<link rel="stylesheet" href="{% getBundleFileUrl "css" %}">

		{#- Or you can add from node_modules #}
		{# <style>{% include "node_modules/something.css" %}</style> #}

		{#- Alternative: render the bundle inline (fastest first paint), requires
			CSP directive style-src: 'unsafe-inline' #}
		{# <style>{% getBundle "css" %}</style> #}

		{#- Add the heading-anchors web component to the JavaScript bundle #}
		<script type="module">{% include "node_modules/@zachleat/heading-anchors/heading-anchors.js" %}</script>

		{#- Example: a hand-written Web Component, no npm package or bundler
			needed. See src/js/components/copy-code-blocks.js #}
		<script type="module">{% include "src/assets/js/components/copy-code-blocks.js" %}</script>
	</head>
	<body>
		<a href="#main" class="skip-link">Skip to main content</a>

		{% include "partials/header.njk" %}

		<main id="main" class="wrapper">
			<heading-anchors>
				<copy-code-blocks>
					{{ content | safe }}
				</copy-code-blocks>
			</heading-anchors>
		</main>

		{% include "partials/footer.njk" %}

		<!-- This page `{{ page.url }}` was built on {% currentBuildDate %} -->
		<script type="module" src="{% getBundleFileUrl "js" %}"></script>
	</body>
</html>
